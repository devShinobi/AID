---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SubmitToolForm from "@/components/react/SubmitToolForm";
import { fetchGroups } from "@/lib/queries/groups";

const groups = await fetchGroups();
---

<BaseLayout title="Submit a Tool" description="Submit an AI tool to be listed in AID — the AI Directory.">
  <div class="mx-auto max-w-2xl px-4 py-10 sm:px-6 lg:px-8">
    <h1 class="mb-2 text-3xl font-bold text-gray-900">Submit a Tool</h1>
    <p class="mb-8 text-gray-500">
      Know a great AI tool that's not listed yet? Submit it and help the community discover it.
    </p>

    <SubmitToolForm groups={groups} client:visible />
  </div>
</BaseLayout>
