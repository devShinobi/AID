---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NewsCard from "@/components/NewsCard.astro";
import Pagination from "@/components/Pagination.astro";
import { fetchNews } from "@/lib/queries/news";
import { getPageFromUrl, buildPaginationMeta, DEFAULT_PAGE_SIZE } from "@/lib/utils/pagination";

const page = getPageFromUrl(Astro.url);
const { news, total } = await fetchNews({ page });
const meta = buildPaginationMeta(page, DEFAULT_PAGE_SIZE, total);
---

<BaseLayout title="AI News" description="Latest news and updates from the AI tools world.">
  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="mb-8 flex items-center justify-between">
      <h1 class="text-3xl font-bold text-gray-100">AI News</h1>
      <span class="text-sm text-gray-500">{total} article{total !== 1 ? "s" : ""}</span>
    </div>

    {news.length > 0 ? (
      <>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {news.map((item) => <NewsCard news={item} />)}
        </div>
        <Pagination meta={meta} baseUrl="/news" />
      </>
    ) : (
      <div class="rounded-xl border border-dashed border-gray-700 py-20 text-center text-gray-600">
        <p class="text-lg font-medium">No news yet</p>
        <p class="mt-1 text-sm">Check back soon.</p>
      </div>
    )}
  </div>
</BaseLayout>
