---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchNewsById } from "@/lib/queries/news";
import { formatDate } from "@/lib/utils/format";

const { id } = Astro.params;
if (!id) return Astro.redirect("/news");

const article = await fetchNewsById(id);
if (!article) return Astro.redirect("/news");

const date = formatDate(article.published_at ?? article.created_at);
---

<BaseLayout title={article.title ?? "News"} description={article.content.slice(0, 160)}>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <article class="rounded-xl border border-gray-200 bg-white p-8 shadow-sm">
      <header class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900 leading-snug">
          {article.title ?? "Untitled"}
        </h1>
        <div class="mt-3 flex flex-wrap items-center gap-4 text-sm text-gray-400">
          <time>{date}</time>
          {article.source_name && <span>Source: {article.source_name}</span>}
        </div>
      </header>

      <div class="prose prose-gray max-w-none text-gray-700 leading-relaxed whitespace-pre-line">
        {article.content}
      </div>

      {article.source_url && (
        <div class="mt-8 border-t border-gray-100 pt-6">
          <a
            href={article.source_url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-indigo-600 hover:underline"
          >
            Read original source →
          </a>
        </div>
      )}
    </article>

    <div class="mt-6 text-center">
      <a href="/news" class="text-sm text-indigo-600 hover:underline">← Back to News</a>
    </div>
  </div>
</BaseLayout>
