---
import type { PaginationMeta } from "@/lib/utils/pagination";

interface Props {
  meta: PaginationMeta;
  baseUrl: string;
  extraParams?: Record<string, string>;
}

const { meta, baseUrl, extraParams = {} } = Astro.props;

function buildUrl(page: number): string {
  const params = new URLSearchParams({ ...extraParams, page: String(page) });
  return `${baseUrl}?${params.toString()}`;
}

const pages = Array.from({ length: meta.totalPages }, (_, i) => i + 1);
const visiblePages = pages.filter(
  (p) => p === 1 || p === meta.totalPages || Math.abs(p - meta.page) <= 2
);
---

{
  meta.totalPages > 1 && (
    <nav class="flex items-center justify-center gap-1 py-6" aria-label="Pagination">
      {meta.hasPrev ? (
        <a
          href={buildUrl(meta.page - 1)}
          class="rounded-md border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-300 hover:bg-gray-800 transition-colors"
        >
          ← Prev
        </a>
      ) : (
        <span class="rounded-md border border-gray-800 bg-gray-900 px-3 py-2 text-sm text-gray-600 cursor-not-allowed">
          ← Prev
        </span>
      )}

      {visiblePages.map((p, i) => {
        const prev = visiblePages[i - 1];
        const showEllipsis = prev !== undefined && p - prev > 1;
        return (
          <>
            {showEllipsis && (
              <span class="px-2 py-2 text-sm text-gray-600">…</span>
            )}
            {p === meta.page ? (
              <span class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white">
                {p}
              </span>
            ) : (
              <a
                href={buildUrl(p)}
                class="rounded-md border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-300 hover:bg-gray-800 transition-colors"
              >
                {p}
              </a>
            )}
          </>
        );
      })}

      {meta.hasNext ? (
        <a
          href={buildUrl(meta.page + 1)}
          class="rounded-md border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-gray-300 hover:bg-gray-800 transition-colors"
        >
          Next →
        </a>
      ) : (
        <span class="rounded-md border border-gray-800 bg-gray-900 px-3 py-2 text-sm text-gray-600 cursor-not-allowed">
          Next →
        </span>
      )}
    </nav>
  )
}
