---
interface Props {
  group: {
    id: string;
    name: string;
    slug: string;
    function?: string;
    toolCount?: number;
  };
  color: { hex: string; bg: string; border: string };
  index: number;
  isActive?: boolean;
}

const { group, color, index, isActive = false } = Astro.props;

function abbr(name: string): string {
  const words = name.split(/\s+/).filter((w) => !["&", "and"].includes(w.toLowerCase()));
  if (words.length >= 2) return words[0][0].toUpperCase() + words[1][0].toLowerCase();
  return name[0].toUpperCase() + (name[1]?.toLowerCase() ?? "");
}

const borderColor = isActive ? color.hex : color.border;
---

<a
  href={`/?group=${group.slug}`}
  class="group relative flex h-20 flex-col items-center justify-between rounded-lg p-2 transition-all duration-200 hover:scale-105 hover:shadow-xl"
  style={`background: ${color.bg}; border: 1.5px solid ${borderColor};`}
  title={group.function}
>
  <!-- Top row: index + flame -->
  <div class="flex w-full items-center justify-between">
    <span class="font-mono text-[9px] text-gray-500">{index}</span>
    {
      (group.toolCount ?? 0) >= 2 && (
        <span class="text-[9px]" title={`${group.toolCount} tools`}>
          🔥
        </span>
      )
    }
  </div>

  <!-- Abbreviation -->
  <span
    class="my-1 font-mono text-2xl font-bold tracking-tight transition-all group-hover:scale-110"
    style={`color: ${color.hex};`}
  >
    {abbr(group.name)}
  </span>

  <!-- Group name -->
  <span class="text-center text-[8px] font-semibold uppercase leading-tight tracking-widest text-gray-400">
    {group.name}
  </span>

  <!-- Active indicator -->
  {
    isActive && (
      <div
        class="absolute inset-0 rounded-xl opacity-10"
        style={`background: ${color.hex};`}
      />
    )
  }
</a>
