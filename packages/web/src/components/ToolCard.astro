---
import PricingBadge from "@/components/PricingBadge.astro";
import { truncate } from "@/lib/utils/format";
import type { Tool } from "@aid/shared/types";

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const excerpt = truncate(tool.overview, 120);
---

<a
  href={`/tools/${tool.slug}`}
  class="group flex flex-col rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition-all hover:border-indigo-300 hover:shadow-md"
>
  <div class="flex items-start justify-between gap-3">
    <h3 class="text-base font-semibold text-gray-900 group-hover:text-indigo-600 transition-colors">
      {tool.name}
    </h3>
    <PricingBadge type={tool.pricing_type} />
  </div>

  <p class="mt-2 flex-1 text-sm text-gray-500 leading-relaxed">
    {excerpt}
  </p>

  {
    tool.groups && tool.groups.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1">
        {tool.groups.slice(0, 3).map((tg) => {
          const group = typeof tg.group_id === "object" ? tg.group_id : null;
          return group ? (
            <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
              {group.name}
            </span>
          ) : null;
        })}
      </div>
    )
  }

  <div class="mt-4 flex items-center text-xs font-medium text-indigo-600 group-hover:underline">
    View details →
  </div>
</a>
