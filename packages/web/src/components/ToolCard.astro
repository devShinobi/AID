---
import PricingBadge from "@/components/PricingBadge.astro";
import { truncate } from "@/lib/utils/format";
import type { Tool } from "@aid/shared/types";

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const excerpt = truncate(tool.overview, 110);
---

<a
  href={`/tools/${tool.slug}`}
  class="group flex flex-col rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all hover:border-indigo-500 hover:shadow-lg hover:shadow-indigo-950/50"
>
  <!-- Logo + name row -->
  <div class="flex items-center gap-3 mb-3">
    {tool.logo_url ? (
      <img
        src={tool.logo_url}
        alt={`${tool.name} logo`}
        width="36"
        height="36"
        class="rounded-lg object-contain bg-white p-0.5 shrink-0"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <span
        class="hidden h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gray-800 text-sm font-bold text-gray-400"
      >
        {tool.name.charAt(0)}
      </span>
    ) : (
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gray-800 text-sm font-bold text-gray-400">
        {tool.name.charAt(0)}
      </span>
    )}
    <div class="flex-1 min-w-0">
      <h3 class="text-base font-semibold text-gray-100 group-hover:text-indigo-400 transition-colors truncate">
        {tool.name}
      </h3>
    </div>
    <PricingBadge type={tool.pricing_type} />
  </div>

  <p class="flex-1 text-sm text-gray-400 leading-relaxed">
    {excerpt}
  </p>

  {tool.groups && tool.groups.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-1">
      {tool.groups.slice(0, 3).map((tg) => {
        const group = typeof tg.group_id === "object" ? tg.group_id : null;
        return group ? (
          <span class="rounded-full bg-gray-800 px-2 py-0.5 text-xs text-gray-400">
            {group.name}
          </span>
        ) : null;
      })}
    </div>
  )}

  <div class="mt-4 flex items-center text-xs font-medium text-indigo-400 group-hover:underline">
    View details →
  </div>
</a>
