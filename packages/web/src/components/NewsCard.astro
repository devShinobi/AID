---
import { formatDate, truncate } from "@/lib/utils/format";
import type { News } from "@aid/shared/types";

interface Props {
  news: News;
}

const { news } = Astro.props;
const excerpt = truncate(news.content, 140);
const date = formatDate(news.published_at ?? news.created_at);
---

<article class="flex flex-col rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all hover:border-indigo-500 hover:shadow-lg hover:shadow-indigo-950/50">
  <div class="flex items-start justify-between gap-2">
    <h3 class="text-base font-semibold text-gray-100 leading-snug">
      {news.title ?? "Untitled"}
    </h3>
    {
      news.source_name && (
        <span class="shrink-0 rounded-full bg-gray-800 px-2 py-0.5 text-xs text-gray-400">
          {news.source_name}
        </span>
      )
    }
  </div>

  <p class="mt-2 flex-1 text-sm text-gray-400 leading-relaxed">{excerpt}</p>

  <div class="mt-4 flex items-center justify-between">
    <time class="text-xs text-gray-600">{date}</time>
    {
      news.source_url ? (
        <a
          href={news.source_url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-medium text-indigo-400 hover:underline"
        >
          Read more →
        </a>
      ) : (
        <a href={`/news/${news.id}`} class="text-xs font-medium text-indigo-400 hover:underline">
          Read more →
        </a>
      )
    }
  </div>
</article>
