---
const year = new Date().getFullYear();

const links = [
  { href: "/tools", label: "Browse Tools" },
  { href: "/news", label: "News" },
  { href: "/faq", label: "FAQ" },
  { href: "/submit", label: "Submit a Tool" },
];
---

<footer class="border-t border-gray-800 bg-gray-950">
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <!-- Brand -->
      <a href="/" class="flex items-center gap-2 text-indigo-400 hover:text-indigo-300">
        <img src="/favicon.svg" alt="AID logo" width="20" height="20" />
        <span class="font-bold">AID</span>
        <span class="text-sm text-gray-500">AI Directory</span>
      </a>

      <!-- Links -->
      <nav class="flex flex-wrap justify-center gap-4">
        {
          links.map(({ href, label }) => (
            <a href={href} class="text-sm text-gray-500 hover:text-gray-200 transition-colors">
              {label}
            </a>
          ))
        }
      </nav>

      <!-- Copyright -->
      <p class="text-sm text-gray-600">&copy; {year} AID. All rights reserved.</p>
    </div>
  </div>
</footer>
