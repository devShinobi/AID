# Copy this to .env in the docker/ directory and fill in real values
# NEVER commit .env to git

# Database
DB_DATABASE=aid
DB_USER=aid_user
DB_PASSWORD=your_strong_password_here

# Directus
DIRECTUS_SECRET=your_very_long_random_secret_here
DIRECTUS_ADMIN_EMAIL=admin@yourdomain.com
DIRECTUS_ADMIN_PASSWORD=your_strong_admin_password_here
DIRECTUS_PUBLIC_URL=https://cms.yourdomain.com

# CORS — your Astro site URL
CORS_ORIGIN=https://yourdomain.com
